# FlaskApp 환경변수 예시
# 실제 값을 채워서 .env로 복사해서 사용 (절대 커밋하지 말 것)

# ── S3 ──────────────────────────────
PHOTOS_BUCKET=             # 필수. S3 버킷명 (팀 확정 필요)
AWS_DEFAULT_REGION=ap-northeast-2

# IAM Role 없을 때만 필요 (EC2 Instance Role 사용 시 불필요)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── MariaDB ─────────────────────────
DATABASE_HOST=172.16.43.160
DATABASE_USER=kosa
DATABASE_PASSWORD=         # 팀원 D 협의
DATABASE_DB_NAME=employees

# ── Flask ───────────────────────────
FLASK_SECRET=              # config.py에 하드코딩 → 추후 Secret으로 교체 예정

# Harbor configuration file (minimal)

hostname: {{ inventory_hostname }}

# http 관련 설정
http:
  port: 80

# 데이터 저장 경로
data_volume: /data

# DB 설정
database:
  password: root123
  max_idle_conns: 50
  max_open_conns: 100

# 초기 어드민 비밀번호
harbor_admin_password: {{ harbor_password | default('Harbor12345') }}

# 기타 기본 설정
trivy:
  enabled: false  # 스캔 기능은 일단 끔 (리소스 절약)
jobservice:
  max_job_workers: 10
notification:
  webhook_job_max_retry: 3
chart:
  absolute_url: false
log:
  level: info
  local:
    rotate_count: 50
    rotate_size: 200M
    location: /var/log/harbor

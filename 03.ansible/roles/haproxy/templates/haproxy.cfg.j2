global
    log /dev/log local0
    log /dev/log local1 notice
    chroot /var/lib/haproxy
    stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
    stats timeout 30s
    user haproxy
    group haproxy
    daemon
    maxconn 4000

defaults
    log     global
    mode    tcp
    option  tcplog
    option  dontlognull
    timeout connect 5000
    timeout client  50000
    timeout server  50000

frontend mysql-read
    bind *:3306
    mode tcp
    option tcplog
    default_backend mysql-read

backend mysql-read
    mode tcp
    option tcp-check
    balance roundrobin
{% for host in groups['percona'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:3306 check
{% endfor %}

frontend mysql-write
    bind *:3307
    mode tcp
    option tcplog
    default_backend mysql-write

backend mysql-write
    mode tcp
    option tcp-check
    balance leastconn
{% for host in groups['percona'] %}
    server {{ host }} {{ hostvars[host]['ansible_host'] }}:3306 check on-marked-down shutdown-sessions
{% endfor %}

frontend stats
    bind *:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /stats
    stats refresh 10s
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}
    stats admin if TRUE

frontend stats
    bind *:{{ haproxy_stats_port }}
    mode http
    stats enable
    stats uri /stats
    stats refresh 10s
    stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}
    stats admin if TRUE
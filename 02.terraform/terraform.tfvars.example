proxmox_api_url           = "https://pve1.example.com:8006/api2/json"
proxmox_api_token_id      = "root@pam!terraform"
proxmox_api_token_secret   = "your-api-token-secret"
proxmox_tls_insecure       = true

cluster_name               = "pxc-prod"
proxmox_nodes              = ["pve1", "pve2", "pve3", "pve4"]

template_vmid              = 9001
template_name              = "ubuntu-22.04-template"

ciuser                     = "kosa"
cipassword                 = "kosa1004"

percona_nodes              = 3
percona_cpu                = 2
percona_memory             = 4096
percona_disk_size          = 60

haproxy_nodes              = 2
haproxy_cpu                = 2
haproxy_memory             = 2048
haproxy_disk_size          = 20

proxysql_nodes             = 2
proxysql_cpu               = 2
proxysql_memory            = 4096
proxysql_disk_size         = 30

storage                    = "rbd-storage"

network_bridge             = "vmbr1"
dmz_vlan_tag               = 20
internal_vlan_tag          = 30

dmz_ip_prefix              = "172.16.20"
internal_ip_prefix         = "172.16.30"
dmz_gateway                = "172.16.20.1"
internal_gateway           = "172.16.30.1"
dns_servers                = ["8.8.8.8", "8.8.4.4"]

ssh_public_key             = "ssh-rsa AAAA..."

ha_enabled                 = true
ha_group                   = "percona-ha"
tags                       = ["percona", "production"]